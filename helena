<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Blog</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header>
    <h1>Meu Blog 📝</h1>
    <p>Ideias, experiências e descobertas.</p>
    <button id="btnTema">🌙 Modo escuro</button>
  </header>

  <main>
    <article>
      <h2>Meu primeiro post</h2>
      <p class="data">📅 Janeiro de 2026</p>
      <img src="https://picsum.photos/600/300?random=1" alt="Imagem do post">
      <p>
        Esse é meu primeiro texto no blog. Aqui vou contar o que aprendi,
        o que me interessa e o que quero explorar. Todo mundo começa do zero —
        e esse é o meu começo.
      </p>
    </article>
  </main>

  <footer>
    <p>Feito por mim 🚀</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>/* ── Modo claro (padrão) ── */
body {
  font-family: Arial, sans-serif;
  background-color: #f5f5f5;
  color: #222222;
  max-width: 680px;
  margin: 0 auto;
  padding: 20px;
}

/* ── Modo escuro (ativado pelo JS) ── */
body.escuro {
  background-color: #1a1a2e;
  color: #e0e0e0;
}

/* ── Header ── */
header {
  text-align: center;
  padding: 30px 20px;
  border-bottom: 2px solid #0d9488;
  margin-bottom: 30px;
}

header h1 {
  font-size: 32px;
  color: #0d9488;
}

header p {
  color: #666666;
  margin-top: 6px;
}

body.escuro header p {
  color: #aaaaaa;
}

/* ── Botão de tema ── */
button {
  margin-top: 14px;
  padding: 8px 18px;
  background-color: #0d9488;
  color: #ffffff;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
}

button:hover {
  background-color: #0f766e;
}

/* ── Post (article) ── */
article {
  background-color: #ffffff;
  border-radius: 10px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

body.escuro article {
  background-color: #16213e;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

article h2 {
  font-size: 22px;
  color: #0d9488;
  margin-bottom: 6px;
}

.data {
  font-size: 13px;
  color: #999999;
  margin-bottom: 14px;
}

article img {
  width: 100%;
  border-radius: 8px;
  margin-bottom: 14px;
}

/* ── Footer ── */
footer {
  text-align: center;
  padding-top: 20px;
  border-top: 1px solid #dddddd;
  color: #999999;
  font-size: 14px;
}
// Pega o botão pelo id "btnTema" que está no HTML
const botao = document.getElementById('btnTema');

// Quando o botão for clicado, executa essa função
botao.addEventListener('click', function() {

  // Adiciona ou remove a classe "escuro" do body
  // classList.toggle = "se não tem, coloca; se já tem, tira"
  document.body.classList.toggle('escuro');

  // Muda o texto do botão dependendo do tema atual
  if (document.body.classList.contains('escuro')) {
    botao.textContent = '☀️ Modo claro';
  } else {
    botao.textContent = '🌙 Modo escuro';
  }

});
